PLSQL SET 15
Write a program that will prompt for a EMPNO,ENAME,SAL.If EMPNO does not exists in EMP table then INSERT the EMPNO,ENAME,SAL into the EMP table else UPDATE NAME,SAL for that EMPNO.


CREATE TABLE EMP(
EMPNO NUMBER PRIMARY KEY,
ENAME VARCHAR2(20),
SAL NUMBER
);
INSERT INTO EMP
VALUES(101,'OM',50000);
INSERT INTO EMP
VALUES(102,'KRUSHNA',40000);
DECLARE
V_EMPNO EMP.EMPNO%TYPE:=&EMPNO;
V_ENAME EMP.ENAME%TYPE:='&ENAME';
V_SAL EMP.SAL%TYPE:=&SAL;
CNT NUMBER;
BEGIN
SELECT COUNT(*)
INTO CNT
FROM EMP
WHERE EMPNO=V_EMPNO;
IF CNT=0 THEN
INSERT INTO EMP
VALUES(V_EMPNO,V_ENAME,V_SAL);
DBMS_OUTPUT.PUT_LINE('RECORD INSERTED');
ELSE
UPDATE EMP
SET ENAME=V_ENAME,
SAL=V_SAL
WHERE EMPNO=V_EMPNO;
DBMS_OUTPUT.PUT_LINE('RECORD UPDATED');
END IF;
END;
/


PLSQL SET 16
Write a program that will prompt for number and display whether the number is ODD or EVEN number.Add user defined exception to check the number is negative.


DECLARE
NUM NUMBER:=&NUM;
NEGATIVE EXCEPTION;
BEGIN
IF NUM<0 THEN
RAISE NEGATIVE;
END IF;
IF MOD(NUM,2)=0 THEN
DBMS_OUTPUT.PUT_LINE('EVEN NUMBER');
ELSE
DBMS_OUTPUT.PUT_LINE('ODD NUMBER');
END IF;
EXCEPTION
WHEN NEGATIVE THEN
DBMS_OUTPUT.PUT_LINE('NEGATIVE NUMBER NOT ALLOWED');
END;
/


PLSQL SET 17
Write program that prompts for EMPNO and update his salary based on the below specification: If the employee belongs to DEPTNO 10 then update his salary by 10%.



CREATE TABLE EMP(
EMPNO NUMBER PRIMARY KEY,
ENAME VARCHAR2(20),
SAL NUMBER,
COMM NUMBER,
DEPTNO NUMBER
);
INSERT INTO EMP
VALUES(101,'OM',50000,2000,10);
INSERT INTO EMP
VALUES(102,'KRUSHNA',40000,3000,20);

INSERT INTO EMP
VALUES(103,'RAHUL',35000,4000,30);
DECLARE
V_EMPNO EMP.EMPNO%TYPE:=&EMPNO;
V_DEPTNO EMP.DEPTNO%TYPE;
V_SAL EMP.SAL%TYPE;
V_COMM EMP.COMM%TYPE;
BEGIN
SELECT DEPTNO,SAL,COMM
INTO V_DEPTNO,V_SAL,V_COMM
FROM EMP
WHERE EMPNO=V_EMPNO;
IF V_DEPTNO=10 THEN
UPDATE EMP
SET SAL=SAL+(SAL*0.10)
WHERE EMPNO=V_EMPNO;
DBMS_OUTPUT.PUT_LINE('10 PERCENT SALARY UPDATED');
ELSIF V_DEPTNO=20 THEN
UPDATE EMP
SET SAL=SAL+(SAL*0.15)
WHERE EMPNO=V_EMPNO;
DBMS_OUTPUT.PUT_LINE('15 PERCENT SALARY UPDATED');
ELSE
UPDATE EMP
SET SAL=SAL+COMM
WHERE EMPNO=V_EMPNO;
DBMS_OUTPUT.PUT_LINE('SALARY + COMM UPDATED');
END IF;
END;
/



