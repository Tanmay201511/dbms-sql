CREATE OR REPLACE PROCEDURE PROC_GRADE(
P_ROLL NUMBER,
P_NAME VARCHAR2,
P_MARKS NUMBER
)
IS
V_CLASS VARCHAR2(30);
BEGIN
IF P_MARKS<=1500 AND P_MARKS>=990 THEN
V_CLASS:='DISTINCTION';
ELSIF P_MARKS BETWEEN 900 AND 989 THEN
V_CLASS:='FIRST CLASS';
