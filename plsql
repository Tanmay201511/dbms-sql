PLSQL SET 21
Write a program that displays the Top N salaries using simple Explicit Cursors.

CREATE TABLE EMP(
EMPNO NUMBER,
ENAME VARCHAR2(20),
SAL NUMBER
);
INSERT INTO EMP
VALUES(101,'OM',50000);
INSERT INTO EMP
VALUES(102,'KRUSHNA',70000);
INSERT INTO EMP
VALUES(103,'RAHUL',45000);
INSERT INTO EMP
VALUES(104,'AMIT',80000);
INSERT INTO EMP
VALUES(105,'ROHAN',60000);
DECLARE
CURSOR C1 IS
SELECT *
FROM EMP
ORDER BY SAL DESC;
V_EMPNO EMP.EMPNO%TYPE;
V_ENAME EMP.ENAME%TYPE;
V_SAL EMP.SAL%TYPE;
N NUMBER:=&N;
COUNT1 NUMBER:=0;
BEGIN

OPEN C1;
LOOP
FETCH C1
INTO V_EMPNO,V_ENAME,V_SAL;
EXIT WHEN C1%NOTFOUND OR COUNT1=N;
DBMS_OUTPUT.PUT_LINE(
V_EMPNO||' '||
V_ENAME||' '||
V_SAL
);
COUNT1:=COUNT1+1;
END LOOP;
CLOSE C1;
END;
/


